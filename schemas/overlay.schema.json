{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/otspace0715/hex-shogun-map/main/schemas/overlay.schema.json",
  "title": "World Overlay Data",
  "description": "1ワールドの全オーバーレイデータを1ファイルで管理。\n城郭・特殊領土・水域・海路を統合。\n世界ごとに概念が異なっても同じ構造で表現できる。",
  "type": "object",
  "required": [
    "meta"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "required": [
        "world_id",
        "version"
      ],
      "properties": {
        "world_id": {
          "type": "string",
          "description": "world.jsonのmeta.world_idと一致"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "landmarks": {
      "description": "ランドマーク（城郭・施設・聖地・要塞都市など）\n世界によって「城」にも「要塞」にも「神殿」にもなる。",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Landmark"
      },
      "default": []
    },
    "special_cells": {
      "description": "特殊領土セル（複数国の条件で出現する特別な地形）\n例: 富士山（甲斐+駿河+相模のいずれか2国）、世界樹（複数王国隣接）",
      "type": "array",
      "items": {
        "$ref": "#/$defs/SpecialTerritory"
      },
      "default": []
    },
    "water_cells": {
      "description": "水域セル（海・湖・河川・その世界固有の水地形）\n例: 駿河湾、精霊の湖、聖なる川",
      "type": "array",
      "items": {
        "$ref": "#/$defs/WaterCell"
      },
      "default": []
    },
    "routes": {
      "description": "移動ルート定義（海路・街道・魔法転送など）\n世界によって「海路」にも「転送門」にもなる。",
      "type": "object",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RouteNode"
          },
          "default": []
        },
        "connections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RouteConnection"
          },
          "default": []
        },
        "island_groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IslandGroup"
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "Landmark": {
      "description": "ランドマーク1件。セル1つを占有する。",
      "type": "object",
      "required": [
        "id",
        "col",
        "row",
        "terrain_type",
        "province"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "col": {
          "type": "integer"
        },
        "row": {
          "type": "integer"
        },
        "lat": {
          "type": "number"
        },
        "lng": {
          "type": "number"
        },
        "terrain_type": {
          "type": "integer",
          "minimum": 0
        },
        "province": {
          "type": "string",
          "description": "所属省/王国名"
        },
        "label": {
          "type": "string",
          "description": "表示名"
        },
        "category": {
          "type": "string",
          "description": "種別ラベル（world固有）例: castle / fortress / temple / shrine"
        },
        "built_year": {
          "type": "string"
        },
        "lord": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "lat_orig": {
          "type": "number"
        },
        "lng_orig": {
          "type": "number"
        },
        "warp_target": {
          "$ref": "#/$defs/WarpTarget"
        }
      },
      "additionalProperties": false
    },
    "WarpTarget": {
      "description": "遷移先メタデータ（SPAモード、座標、時間経過など）",
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "world",
            "subgrid",
            "interior"
          ],
          "description": "遷移先の描画モード"
        },
        "p": {
          "type": "string",
          "description": "遷移先の地方/省名"
        },
        "id": {
          "type": "string",
          "description": "遷移先のセルIDまたはランドマークID"
        },
        "label": {
          "type": "string",
          "description": "遷移先のラベル（ツールチップ表示用）"
        },
        "sources": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ],
          "description": "ロードするデータソースのシーケンス番号（001, 002など）"
        },
        "time_delta": {
          "type": "object",
          "properties": {
            "years": {
              "type": "number"
            },
            "months": {
              "type": "number"
            },
            "days": {
              "type": "number"
            }
          },
          "description": "移動に伴う時間経過"
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "SpecialTerritory": {
      "description": "複数国の条件で出現する特殊領土。複数セルを持てる。",
      "type": "object",
      "required": [
        "id",
        "trigger_provinces",
        "cells"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "trigger_condition": {
          "type": "string",
          "enum": [
            "any",
            "all",
            "any2"
          ],
          "default": "any"
        },
        "trigger_provinces": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "cells": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "col",
              "row",
              "terrain_type"
            ],
            "properties": {
              "col": {
                "type": "integer"
              },
              "row": {
                "type": "integer"
              },
              "lat": {
                "type": "number"
              },
              "lng": {
                "type": "number"
              },
              "hex_id": {
                "type": "string"
              },
              "terrain_type": {
                "type": "integer"
              },
              "capturable": {
                "type": "boolean"
              },
              "cost": {
                "type": "number"
              },
              "label": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "WaterCell": {
      "description": "水域セル1件。trigger_provincesのいずれかがアクティブな時に表示。",
      "type": "object",
      "required": [
        "id",
        "col",
        "row",
        "water_type",
        "trigger_provinces"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "col": {
          "type": "integer"
        },
        "row": {
          "type": "integer"
        },
        "lat": {
          "type": "number"
        },
        "lng": {
          "type": "number"
        },
        "water_type": {
          "type": "string",
          "enum": [
            "sea",
            "lake",
            "river"
          ],
          "description": "sea=海域, lake=湖, river=河川"
        },
        "label": {
          "type": "string",
          "description": "表示名（例: 駿河湾、精霊の湖）"
        },
        "terrain_type": {
          "type": "integer"
        },
        "trigger_provinces": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "trigger_condition": {
          "type": "string",
          "enum": [
            "any",
            "all",
            "any2"
          ],
          "default": "any"
        },
        "flood_risk": {
          "type": "boolean"
        },
        "capturable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "RouteNode": {
      "description": "ルートの拠点（港・街道宿・転送門など）",
      "type": "object",
      "required": [
        "id",
        "col",
        "row",
        "province"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "col": {
          "type": "integer"
        },
        "row": {
          "type": "integer"
        },
        "lat": {
          "type": "number"
        },
        "lng": {
          "type": "number"
        },
        "province": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "種別（harbor / gate / town など）"
        },
        "note": {
          "type": "string"
        },
        "warp_target": {
          "$ref": "#/$defs/WarpTarget"
        }
      },
      "additionalProperties": false
    },
    "RouteConnection": {
      "description": "2拠点間の接続（航路・街道・魔法リンクなど）",
      "type": "object",
      "required": [
        "id",
        "from_node",
        "to_node"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "from_node": {
          "type": "string",
          "description": "RouteNode.idと一致"
        },
        "to_node": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "distance_km": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "cost": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "bidirectional": {
          "type": "boolean",
          "default": true
        },
        "condition": {
          "type": "string",
          "description": "利用条件（例: ship_level>=1）"
        },
        "season": {
          "type": "string"
        },
        "is_island_route": {
          "type": "boolean",
          "default": false
        },
        "waypoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "col",
              "row"
            ],
            "properties": {
              "col": {
                "type": "integer"
              },
              "row": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "IslandGroup": {
      "description": "島嶼グループ（伊豆諸島など）",
      "type": "object",
      "required": [
        "id",
        "province",
        "islands"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "province": {
          "type": "string"
        },
        "islands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "cells"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "cells": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "col",
                    "row"
                  ],
                  "properties": {
                    "col": {
                      "type": "integer"
                    },
                    "row": {
                      "type": "integer"
                    },
                    "terrain_type": {
                      "type": "integer"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}