{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/otspace0715/hex-shogun-map/main/schemas/world.schema.json",
  "title": "World Definition",
  "description": "ヘックスマップビューワーのワールド定義ファイル。world.jsonとworld_*.jsonに適用される。",
  "type": "object",
  "required": [
    "meta",
    "coordinate",
    "api",
    "terrain_types",
    "provinces"
  ],
  "properties": {
    "meta": {
      "description": "ワールドのメタ情報",
      "type": "object",
      "required": [
        "world_id",
        "name",
        "version"
      ],
      "properties": {
        "world_id": {
          "type": "string",
          "description": "ワールドの一意ID（英数字・アンダースコア）",
          "pattern": "^[a-z0-9_]+$"
        },
        "name": {
          "type": "string",
          "description": "表示名（多言語可）"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "description": "semver形式推奨",
          "examples": [
            "1.0.0"
          ]
        }
      },
      "additionalProperties": false
    },
    "coordinate": {
      "description": "ヘックスグリッドの座標原点とピッチ定義",
      "type": "object",
      "required": [
        "origin_lat",
        "origin_lng",
        "lat_step",
        "lng_step"
      ],
      "properties": {
        "origin_lat": {
          "type": "number",
          "description": "グリッド原点の緯度（row=0の基準）"
        },
        "origin_lng": {
          "type": "number",
          "description": "グリッド原点の経度（col=0の基準）"
        },
        "lat_step": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "1行あたりの緯度ステップ（LAT2 = lat_step * 2）"
        },
        "lng_step": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "1列あたりの経度ステップ"
        },
        "coordinate_system": {
          "type": "string",
          "enum": [
            "geo",
            "grid"
          ],
          "default": "geo",
          "description": "geo=実座標(GPS連携可) / grid=架空座標"
        },
        "cell_size_km": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "1セルの現実距離（km）。架空世界での設定値。"
        },
        "world_size": {
          "type": "object",
          "properties": {
            "width_cells": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "height_cells": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "description": {
              "type": "string"
            }
          }
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "api": {
      "description": "データ取得先のURL定義",
      "type": "object",
      "required": [
        "province_base"
      ],
      "properties": {
        "province_base": {
          "type": "string",
          "format": "uri",
          "description": "省/地域JSONの基底URL。{name}.jsonが付加される。"
        },
        "specials": {
          "type": "string",
          "format": "uri",
          "description": "特殊領土JSONのURL"
        },
        "sea_routes": {
          "type": "string",
          "format": "uri",
          "description": "海路JSONのURL"
        },
        "water_cells": {
          "type": "string",
          "format": "uri",
          "description": "水域セルJSONのURL"
        },
        "castles": {
          "type": "string",
          "format": "uri",
          "description": "城郭/施設JSONのURL"
        }
      },
      "additionalProperties": false
    },
    "terrain_types": {
      "description": "地形タイプの定義。キーは0〜99の整数文字列。",
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[0-9]{1,2}$": {
          "type": "object",
          "required": [
            "name",
            "color",
            "passable",
            "capturable",
            "cost"
          ],
          "properties": {
            "name": {
              "type": "string",
              "description": "地形名（i18nで上書き可）"
            },
            "color": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "minItems": 3,
              "maxItems": 3,
              "description": "[R, G, B]"
            },
            "passable": {
              "type": "boolean",
              "description": "陸上移動で通過可能か"
            },
            "capturable": {
              "type": "boolean",
              "description": "領地化可能か"
            },
            "cost": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "移動コスト（1.0=平地基準）"
            },
            "ship_only": {
              "type": "boolean",
              "description": "船でのみ移動可能（海域用）"
            },
            "flood_risk": {
              "type": "boolean",
              "description": "水害リスクあり（河川用）"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "provinces": {
      "description": "省/地域/王国の定義リスト",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "color"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "英数字ID（ボタンのHTMLid: p-{id}）"
          },
          "name": {
            "type": "string",
            "description": "表示名（HTMLのdata-prov属性と一致する必要がある）"
          },
          "color": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            },
            "minItems": 3,
            "maxItems": 3,
            "description": "領地色 [R, G, B]"
          },
          "region": {
            "type": "string",
            "description": "地方区分（五畿内・東海道など）"
          }
        },
        "additionalProperties": false
      }
    },
    "i18n": {
      "description": "UIテキストの多言語定義。app.js内のt('key')で参照される。",
      "type": "object",
      "properties": {
        "ui.select_region": {
          "type": "string"
        },
        "ui.tap_cell": {
          "type": "string"
        },
        "ui.loading": {
          "type": "string"
        },
        "ui.error": {
          "type": "string"
        },
        "ui.cells": {
          "type": "string"
        },
        "ui.gps_searching": {
          "type": "string"
        },
        "ui.gps_failed": {
          "type": "string"
        },
        "ui.gps_outside": {
          "type": "string"
        },
        "ui.gps_stop": {
          "type": "string"
        },
        "ui.gps_start": {
          "type": "string"
        },
        "ui.spawn_tap": {
          "type": "string"
        },
        "ui.spawn_cancel": {
          "type": "string"
        },
        "ui.spawn_set": {
          "type": "string"
        },
        "ui.normal_mode": {
          "type": "string"
        },
        "ui.shared_edges": {
          "type": "string"
        },
        "ui.cost": {
          "type": "string"
        },
        "ui.built": {
          "type": "string"
        },
        "ui.lord": {
          "type": "string"
        },
        "cell.border": {
          "type": "string"
        },
        "cell.port": {
          "type": "string"
        },
        "cell.castle": {
          "type": "string"
        },
        "cell.sea": {
          "type": "string"
        },
        "cell.river": {
          "type": "string"
        },
        "cell.flood": {
          "type": "string"
        },
        "cell.lake": {
          "type": "string"
        },
        "cell.sea_route": {
          "type": "string"
        },
        "cell.special": {
          "type": "string"
        },
        "cell.island": {
          "type": "string"
        },
        "cell.unknown_sea": {
          "type": "string"
        },
        "cell.unknown_lake": {
          "type": "string"
        },
        "cell.unknown_river": {
          "type": "string"
        },
        "cell.unknown_border": {
          "type": "string"
        },
        "cell.unknown_auto": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "simulation": {
      "description": "シミュレーションの初期状態設定",
      "type": "object",
      "properties": {
        "start_year": {
          "type": "integer",
          "description": "シミュレーション開始年度"
        },
        "default_season": {
          "type": "string",
          "enum": [
            "spring",
            "summer",
            "autumn",
            "winter"
          ],
          "description": "初期表示季節"
        },
        "time_speed": {
          "type": "number",
          "description": "時間の進む速さ（倍率）"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}